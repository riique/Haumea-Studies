# Exemplo de .env.local para desenvolvimento local
# Use este arquivo ao rodar o emulator localmente

# Open Router API Key para testes locais
OPENROUTER_API_KEY=COLE_SUA_OPENROUTER_API_KEY_DE_DESENVOLVIMENTO_AQUI

# Dicas para desenvolvimento:
# 1. Crie uma API Key separada apenas para desenvolvimento
# 2. Configure limites de gasto para evitar surpresas
# 3. Nunca use a mesma key de produção
